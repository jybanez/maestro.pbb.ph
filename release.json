{
  "schema_version": 1,
  "app": "pbb-maestro",
  "name": "PBB Maestro",
  "milestone": 1,
  "version": "1.0.0",
  "display_version": "v1-1.0.0",
  "release_date": "2026-05-15",
  "release_name": "Kit Setup Installer Contract",
  "type": "laravel",
  "repository": {
    "type": "github",
    "owner": "jybanez",
    "repo": "maestro.pbb.ph",
    "url": "https://github.com/jybanez/maestro.pbb.ph"
  },
  "updates": {
    "source": "github-releases",
    "channel": "testing"
  },
  "requires": {
    "os": ["windows", "linux"],
    "php": ">=8.2",
    "php_extensions": ["json", "openssl", "mbstring", "fileinfo", "zip", "pdo", "pdo_mysql", "tokenizer", "xml", "ctype"],
    "mysql": ">=5.7",
    "node": "not-required-static-assets-present",
    "composer": "not-required-vendor-bundled"
  },
  "installer": {
    "interactive": "installer/index.php",
    "unattended": "installer/install-run.php",
    "status": "installer/status.php",
    "schema": "installer/schema/install.schema.json",
    "database": {
      "fresh_install_strategy": "baseline_schema",
      "baseline_schema": {
        "path": "database/schema/mysql-fresh.sql",
        "engine": "mysql",
        "generated_at": "2026-05-18T15:49:25+08:00",
        "source": "current-release-schema"
      },
      "upgrade_strategy": "laravel_migrations"
    },
    "tools": {
      "populate_initial_data": {
        "path": "tools/populate-initial-data.php",
        "description": "Register known Maestro monitored applications and optional telemetry tokens.",
        "config_section": "maestro.populate",
        "default_source": "resources/data/maestro/applications.json",
        "required": false
      }
    }
  },
  "data_prep": {
    "version": 1,
    "capabilities": {
      "prepare_data": true,
      "apply_settings": false,
      "verify": true
    },
    "tools": {
      "prepare_data": {
        "path": "tools/populate-initial-data.php",
        "description": "Prepare Relay and Realtime Maestro application profiles and runtime-injected telemetry token hashes.",
        "config_section": "maestro.populate",
        "default_source": "resources/data/maestro/applications.json"
      },
      "verify": {
        "path": "tools/data-prep/verify.php",
        "description": "Verify Relay and Realtime Maestro application profiles, active Primary telemetry token hashes, and heartbeat freshness status.",
        "config_section": "maestro.data_prep.verify",
        "default_source": "resources/data/maestro/applications.json"
      }
    }
  },
  "update": {
    "contract_version": 1,
    "channel": "testing",
    "immutable_release": false,
    "from_versions": ["1.0.0"],
    "compatibility": "same-version-rebuild",
    "requires_database_migration": false,
    "requires_data_prep_rerun": false,
    "requires_service_restart": false,
    "rollback_supported": true
  },
  "health": {
    "http": "/up",
    "bootstrap": "/api/bootstrap",
    "internal": "/internal-health"
  },
  "services": [
    {
      "id": "pbb-maestro-scheduler",
      "name": "PBB Maestro Scheduler",
      "kind": "scheduler",
      "command": "php artisan schedule:run",
      "required": true,
      "healthcheck": "php artisan maestro:reconcile-stale-workers"
    }
  ],
  "artifacts": {
    "install_manifest": "storage/app/installer/install-manifest.json",
    "install_report": "storage/app/installer/install-report.json",
    "install_log": "storage/app/installer/install.log"
  }
}
