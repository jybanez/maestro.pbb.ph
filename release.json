{
  "schema_version": 1,
  "app": "pbb-maestro",
  "name": "PBB Maestro",
  "display_name": "Maestro",
  "milestone": 1,
  "version": "1.0.0",
  "display_version": "v1-1.0.0",
  "release_date": "2026-05-15",
  "release_name": "Kit Setup Installer Contract",
  "type": "laravel",
  "repository": {
    "type": "github",
    "owner": "jybanez",
    "repo": "maestro.pbb.ph",
    "url": "https://github.com/jybanez/maestro.pbb.ph"
  },
  "updates": {
    "source": "github-releases",
    "channel": "testing"
  },
  "requires": {
    "os": ["windows", "linux"],
    "runtime": {
      "pbb_ca_bundle": true
    },
    "php": ">=8.2",
    "php_extensions": ["json", "openssl", "mbstring", "fileinfo", "zip", "pdo", "pdo_mysql", "tokenizer", "xml", "ctype"],
    "mysql": ">=5.7",
    "node": "not-required-static-assets-present",
    "composer": "not-required-vendor-bundled"
  },
  "installer": {
    "interactive": "installer/index.php",
    "unattended": "installer/install-run.php",
    "status": "installer/status.php",
    "schema": "installer/schema/install.schema.json",
    "database": {
      "fresh_install_strategy": "baseline_schema",
      "baseline_schema": {
        "path": "database/schema/mysql-fresh.sql",
        "engine": "mysql",
        "generated_at": "2026-05-18T15:49:25+08:00",
        "source": "current-release-schema"
      },
      "upgrade_strategy": "laravel_migrations"
    },
    "tools": {
      "populate_initial_data": {
        "path": "tools/populate-initial-data.php",
        "description": "Register known Maestro monitored applications and optional telemetry tokens.",
        "config_section": "maestro.populate",
        "default_source": "resources/data/maestro/applications.json",
        "required": false
      }
    }
  },
  "data_prep": {
    "version": 1,
    "capabilities": {
      "prepare_data": true,
      "apply_settings": false,
      "verify": true
    },
    "tools": {
      "prepare_data": {
        "path": "tools/populate-initial-data.php",
        "description": "Prepare Relay and Realtime Maestro application profiles and runtime-injected telemetry token hashes.",
        "config_section": "maestro.populate",
        "default_source": "resources/data/maestro/applications.json"
      },
      "verify": {
        "path": "tools/data-prep/verify.php",
        "description": "Verify Relay and Realtime Maestro application profiles, active Primary telemetry token hashes, and heartbeat freshness status.",
        "config_section": "maestro.data_prep.verify",
        "default_source": "resources/data/maestro/applications.json"
      }
    }
  },
  "update": {
    "contract_version": 1,
    "channel": "testing",
    "immutable_release": false,
    "from_versions": ["1.0.0"],
    "compatibility": "same-version-rebuild",
    "requires_database_migration": true,
    "database_migration": {
      "policy": "additive-preservative",
      "notes": "Adds nullable users.pbb_user_id, user role/status fields, and DB-backed Maestro app-admin settings."
    },
    "requires_data_prep_rerun": false,
    "requires_service_restart": false,
    "rollback_supported": true
  },
  "health": {
    "http": "/up",
    "bootstrap": "/api/bootstrap",
    "internal": "/internal-health"
  },
  "account_integration": {
    "client_id": "pbb-maestro",
    "display_name": "Maestro",
    "local_base_url": "https://maestro.pbb.ph",
    "sso": {
      "enabled_by_default": false,
      "runtime_settings_source": "database",
      "settings_ui": true,
      "callback_url": "https://maestro.pbb.ph/auth/account/callback",
      "post_logout_redirect_url": "https://maestro.pbb.ph",
      "scopes": ["openid", "profile"],
      "env": {
        "base_url": "PBB_ACCOUNT_BASE_URL",
        "client_id": "PBB_ACCOUNT_CLIENT_ID",
        "client_secret": "PBB_ACCOUNT_CLIENT_SECRET",
        "redirect_uri": "PBB_ACCOUNT_REDIRECT_URI",
        "post_logout_redirect_uri": "PBB_ACCOUNT_POST_LOGOUT_REDIRECT_URI"
      }
    },
    "app_admin": {
      "enabled_by_default": false,
      "base_url": "https://maestro.pbb.ph",
      "api_base_path": "/api/account-admin",
      "token_strategy": "kit-generate-or-import",
      "runtime_settings_source": "database",
      "settings_ui": true,
      "bootstrap_env": {
        "enabled": "PBB_MAESTRO_ACCOUNT_ADMIN_API_ENABLED",
        "client": "PBB_MAESTRO_ACCOUNT_ADMIN_API_CLIENT",
        "token": "PBB_MAESTRO_ACCOUNT_ADMIN_API_TOKEN"
      },
      "meta_endpoint": "/api/account-admin/meta",
      "roles": ["admin", "user"],
      "statuses": ["active", "disabled"],
      "requires_database_migration": true
    }
  },
  "landing": {
    "launcher": {
      "icon": "activity",
      "primary_launch_url": "https://maestro.pbb.ph/",
      "audience": ["operator", "command", "admin"]
    },
    "public_gateway": {
      "enabled": false
    }
  },
  "runtime_services": [
    {
      "id": "pbb-maestro-scheduler",
      "name": "PBB Maestro Scheduler",
      "type": "scheduled_command",
      "required": true,
      "required_for_smoke": false,
      "manager": "kit",
      "working_directory": "{app.install_path}",
      "command": "{runtime.php_binary}",
      "args": ["artisan", "schedule:run"],
      "interval_seconds": 60,
      "startup_mode": "automatic",
      "health_check": {
        "type": "command",
        "command": "{runtime.php_binary}",
        "args": ["artisan", "maestro:reconcile-stale-workers"],
        "timeout_seconds": 30
      },
      "logs": {
        "stdout": "storage/logs/pbb-maestro-scheduler.out.log",
        "stderr": "storage/logs/pbb-maestro-scheduler.err.log"
      },
      "notes": "Kit registers or starts the Laravel scheduler runner; the app installer only generates service artifacts."
    }
  ],
  "artifacts": {
    "install_manifest": "storage/app/installer/install-manifest.json",
    "install_report": "storage/app/installer/install-report.json",
    "install_log": "storage/app/installer/install.log"
  }
}
